# Supabase (find these in your Supabase project: Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: defaults to NEXT_PUBLIC_SUPABASE_URL on the server if unset
SUPABASE_URL=https://your-project-ref.supabase.co

# Initial admin seeded by `npm run supabase:seed`
SEED_ADMIN_EMAIL=admin@stmark.com
SEED_ADMIN_PASSWORD=change-me-strong-password
SEED_ADMIN_STUDENT_NUMBER=ADMIN001
